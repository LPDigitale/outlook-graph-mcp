# Copiez ce fichier en .env (ou définissez ces variables dans la config MCP de Claude).

# Obligatoire : « Application (client) ID » de votre app Azure AD
OUTLOOK_MCP_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Recommandé (compte pro mono-tenant) : « Directory (tenant) ID » (GUID) ou domaine
# 'organizations' = tout compte pro/école ; 'common' = pro + perso
OUTLOOK_MCP_TENANT_ID=00000000-0000-0000-0000-000000000000

# Optionnel — laissez par défaut sauf besoin particulier
# OUTLOOK_MCP_SCOPES=Mail.ReadWrite Mail.Send MailboxSettings.ReadWrite
# OUTLOOK_MCP_IMMUTABLE_IDS=true
# OUTLOOK_MCP_CACHE_DIR=%USERPROFILE%\.outlook-graph-mcp
